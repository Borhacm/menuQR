# Database — Postgres debe estar escuchando (por defecto 127.0.0.1:5433):
#   1) Arranca Docker Desktop
#   2) npm run db:up
#   3) npm run db:migrate:deploy   (primera vez o tras pull de migraciones)
DATABASE_URL="postgresql://menuly:menuly@127.0.0.1:5433/menuly?schema=public"
# Vercel: to run migrations on each production build, set Build Command to `npm run vercel:build`
# and expose DATABASE_URL for "Build" (not only Runtime) in Project Settings → Environment Variables.

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (transactional email)
RESEND_API_KEY=""
RESEND_FROM="Menuly <onboarding@menuly.test>"

# OpenAI
OPENAI_API_KEY=""

# Translation provider
# auto -> tries LibreTranslate, then OpenAI, then suffix fallback
# libretranslate -> force local LibreTranslate
# openai -> force OpenAI
# suffix -> no external API, appends locale marker
TRANSLATE_PROVIDER="auto"
LIBRETRANSLATE_URL="http://127.0.0.1:5001/translate"
LIBRETRANSLATE_PRIMARY_LOCALES="en,es,fr,de,it,pt,ca,ko"
LIBRETRANSLATE_SOURCE_LOCALE="auto"
LIBRETRANSLATE_TIMEOUT_MS="25000"
# Optional secondary LibreTranslate endpoint (useful for locales
# not supported by your local instance, e.g. nl,ru in development)
LIBRETRANSLATE_URL_SECONDARY="http://127.0.0.1:5002/translate"
LIBRETRANSLATE_SECONDARY_LOCALES="nl,ru"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_STANDARD_PLUS=""

# Public site (origin only, no path — avoids broken metadata / OG URLs in Next.js)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: canonical marketing landing (logo "M" in QR menus). Set in production if menus
# live on another host or the landing path is not the app root. See PENDIENTES.md.
NEXT_PUBLIC_MARKETING_SITE_URL=""
# Hostname routing: single root default, or list several (comma-separated) with NEXT_PUBLIC_ROOT_DOMAINS.
# Longest-match wins so both bocal.online and menuly.bocal.online can coexist: the menu host apex
# is not mistaken for tenant subdomain "menuly". Public menus stay at NEXT_PUBLIC_APP_URL/m/<slug>
# (unless NEXT_PUBLIC_PUBLIC_MENU_URL is set below).
NEXT_PUBLIC_ROOT_DOMAIN="menuly.test"
# NEXT_PUBLIC_ROOT_DOMAINS="bocal.online,menuly.bocal.online"
# QR codes embed this URL + /m/<slug>. Override when admin runs on another origin than the menu hostname.
NEXT_PUBLIC_PUBLIC_MENU_URL=""
# Analytics feature flags
NEXT_PUBLIC_ENABLE_ITEM_ANALYTICS="false"

# Upload storage
# local -> writes to public/uploads
# external -> PUT to UPLOAD_EXTERNAL_BASE_URL/uploads/<fileName>
UPLOAD_STORAGE_MODE="local"
UPLOAD_EXTERNAL_BASE_URL=""
UPLOAD_EXTERNAL_WRITE_TOKEN=""

# Internal metrics endpoint protection (optional)
METRICS_TOKEN=""
